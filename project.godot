; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Q42_Startrek"
run/main_scene="uid://dwhueejuj0whx"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://wqx7dv3snxly"

[autoload]

ReputationSystem="*res://scripts/autoloads/reputation_system.gd"
FactionSystem="*res://scripts/autoloads/faction_system.gd"
PhaserAudioPool="*res://scenes/audio/phaser_audio_pool.tscn"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
DebugManager="*res://scripts/autoloads/debug_manager.gd"
RelationshipResolver="*res://scripts/autoloads/relationship_resolver.gd"

[display]

window/size/viewport_width=2360
window/size/viewport_height=1240
window/size/mode=2
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/brackeys_particle_controls/plugin.cfg")

